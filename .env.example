# API keys for LLM providers (used by LiteLLM)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Gemini/Google (for gemini/* models)
GEMINI_API_KEY=
# Hugging Face Inference Providers (for huggingface/<provider>/<org>/<model> models).
# Get one at https://huggingface.co/settings/tokens with "Inference Providers" scope.
HF_TOKEN=
